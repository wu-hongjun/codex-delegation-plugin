node_modules/
# T9.5: re-include the bundled-dep tree under the marketplace plugin.
# `codex plugin add` materialises only what is committed under
# marketplace/plugins/delegate/; the dispatcher must resolve
# @codex-delegation/runtime + driver + node-pty from this committed payload.
!marketplace/plugins/delegate/node_modules/
dist/
# T9.5: re-include the bundled-dep dist directories (runtime + driver) that
# live under the marketplace plugin's bundled node_modules. They are the
# compiled JS the dispatcher imports at cache-execution time.
!marketplace/plugins/delegate/node_modules/**/dist/
!marketplace/plugins/delegate/node_modules/**/dist/**
*.tsbuildinfo
.tsbuildinfo
.DS_Store
*.log
.env
.env.local
.npm/
.eslintcache
coverage/
_site/
.omc/

# Codex CLI writes this local install marker into marketplace Git clones.
# Keep `git status --short` clean after `codex plugin marketplace upgrade`.
.codex-marketplace-install.json

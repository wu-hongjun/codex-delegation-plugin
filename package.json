{
  "name": "codex-delegation-plugin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Codex delegation runtime for Claude Code and Google Antigravity. See README.md.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --build",
    "build": "tsc --build",
    "clean": "tsc --build --clean && rimraf packages/*/dist",
    "test": "npm run test:mock && npm run test:runtime && npm run test:driver && npm run test:plugin",
    "test:mock": "node --test tools/mock-claude/test/*.test.mjs tools/mock-codex/test/*.test.mjs tools/mock-agy/test/*.test.mjs",
    "test:runtime": "npm run build && node --test packages/runtime/test/*.test.mjs",
    "test:doctor": "npm run build && node --test packages/runtime/test/doctor.test.mjs",
    "test:driver": "npm run build && node --test --test-concurrency=4 packages/driver-claude-code/test/*.test.mjs packages/driver-agy-cli/test/*.test.mjs packages/driver-pi-cli/test/*.test.mjs packages/driver-qwen-code/test/*.test.mjs",
    "test:plugin": "npm run build && node --test packages/plugin-delegate/test/*.test.mjs",
    "test:attach": "npm run build && node --test packages/driver-claude-code/test/send.test.mjs",
    "test:bench": "node --test tools/bench/test/*.test.mjs tools/bench/test/runners/*.test.mjs",
    "site:build": "node tools/site/build.mjs",
    "site:check": "node tools/site/check.mjs",
    "site:test:commands": "node tools/site/test-command-reference.mjs",
    "site:test": "npm run build && npm run site:build && npm run site:check && npm run site:test:commands",
    "site:serve": "node tools/site/serve.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^20.16.0",
    "eslint": "^9.10.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}

#!/usr/bin/env node
// Mock `claude` binary for testing cc-plugin-codex without touching real Claude Code.
//
// This script intentionally implements only enough of the real `claude` command surface
// to support the runtime, driver, and dispatcher tests in plan 0001. It is NOT a faithful
// reimplementation. See tools/mock-claude/README.md for the contract.
//
// Environment:
//   CC_PLUGIN_CODEX_MOCK_CLAUDE_HOME   — state directory. Defaults to a safe temp path.
//                                         Tests MUST set this to an isolated directory.
//   CC_PLUGIN_CODEX_MOCK_CLAUDE_CONFIG — path to a JSON config file controlling fixture
//                                         behavior (version, authStatus, daemonStatus,
//                                         bgFails, agentsJsonMalformed, logsFail,
//                                         agentsJsonSchema, bgStdoutStyle,
//                                         daemonAvailable, helpListsBg).
//
// The mock never writes to ~/.claude and never makes network calls.

import { appendFileSync, existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';
import { tmpdir } from 'node:os';
import { dirname, join } from 'node:path';
import { randomBytes } from 'node:crypto';
import { fileURLToPath } from 'node:url';

// Directory containing the mock binary — used to locate fixture files.
const MOCK_DIR = dirname(fileURLToPath(import.meta.url));

const DEFAULT_HOME = join(tmpdir(), 'cc-plugin-codex-mock-claude');
const HOME = process.env.CC_PLUGIN_CODEX_MOCK_CLAUDE_HOME || DEFAULT_HOME;
const CONFIG_PATH = process.env.CC_PLUGIN_CODEX_MOCK_CLAUDE_CONFIG;

const DEFAULT_CONFIG = Object.freeze({
  version: '2.1.999-mock',
  authStatus: 'authenticated',
  daemonStatus: 'running',
  bgFails: false,
  agentsJsonMalformed: false,
  agentsJsonFails: false,
  logsFail: false,
  sleepMs: 0,
  // Schema mode: "real-2.1.149" (default) | "mock" (legacy)
  agentsJsonSchema: 'real-2.1.149',
  // Stdout style for --bg: "backgrounded" (default) | "started-session" (legacy)
  bgStdoutStyle: 'backgrounded',
  // Whether "daemon status" subcommand is available (false = real mode, true = legacy mock mode)
  daemonAvailable: false,
  // Whether --help lists --bg (false = real mode, true = legacy mock mode)
  helpListsBg: false,
  // Plan 0002: whether `claude attach --help` is recognized (true = real mode).
  // Flip to false in tests to exercise the doctor's claude-attach-help failure path.
  attachHelpAvailable: true,
  // Plan 0002: whether `claude --bg --help` is recognized (true = real mode).
  // Flip to false in tests to exercise the doctor's claude-bg-no-prompt failure path.
  bgNoPromptAvailable: true,
  // Plan 0002 T3: response template for attach and bg turns.
  // The literal substring "${prompt}" is replaced with the submitted prompt.
  attachResponse: '[mock] Got: ${prompt}',
  // Plan 0002 T3: when true the FIRST submit under each attach transitions through
  // a "waiting" (permission) state before processing the turn.
  permissionStall: false,
  // Plan 0003 T9: review fixture selection.
  // Valid values: "structured-review" | "malformed-review" | "adversarial-review".
  // When unset (null), the mock auto-selects based on the detected prompt type:
  //   attach path → "structured-review"
  //   --bg path   → "adversarial-review"
  reviewFixture: null,
});

function loadConfig() {
  if (!CONFIG_PATH) return { ...DEFAULT_CONFIG };
  if (!existsSync(CONFIG_PATH)) return { ...DEFAULT_CONFIG };
  try {
    const raw = readFileSync(CONFIG_PATH, 'utf8');
    return { ...DEFAULT_CONFIG, ...JSON.parse(raw) };
  } catch {
    return { ...DEFAULT_CONFIG };
  }
}

function ensureHome() {
  mkdirSync(HOME, { recursive: true });
  mkdirSync(join(HOME, 'projects'), { recursive: true });
  mkdirSync(join(HOME, 'logs'), { recursive: true });
  // Plan 0002: emulate real Claude's `~/.claude/jobs/` sidecar directory. Plan 0002's
  // doctor probe `sidecar-jobs-dir` checks for this dir; healthy mocks must include it.
  // T3 will populate per-session sidecar files (state.json + timeline.jsonl) under
  // <HOME>/jobs/<shortId>/.
  mkdirSync(join(HOME, 'jobs'), { recursive: true });
}

function statePath() {
  return join(HOME, 'state.json');
}

function loadState() {
  // Intentionally does NOT call ensureHome(). Read-only probes (`agents --json`,
  // `logs`, `stop` on a missing id) must not create directories as a side effect —
  // otherwise the runtime doctor's transcript-path probe sees a freshly-created
  // `<HOME>/projects/` and thinks the transcript dir exists.
  const p = statePath();
  if (!existsSync(p)) return { sessions: [] };
  try {
    return JSON.parse(readFileSync(p, 'utf8'));
  } catch {
    return { sessions: [] };
  }
}

function saveState(state) {
  mkdirSync(HOME, { recursive: true });
  writeFileSync(statePath(), JSON.stringify(state, null, 2));
}

// Generate a UUID-like string formatted as XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
function newUUID() {
  const b = randomBytes(16);
  // Set version 4 bits
  b[6] = (b[6] & 0x0f) | 0x40;
  // Set variant bits
  b[8] = (b[8] & 0x3f) | 0x80;
  const hex = b.toString('hex');
  return [
    hex.slice(0, 8),
    hex.slice(8, 12),
    hex.slice(12, 16),
    hex.slice(16, 20),
    hex.slice(20, 32),
  ].join('-');
}

// Derive 8-char hex shortId from UUID by stripping hyphens and taking first 8 chars
function deriveShortIdFromUUID(uuid) {
  return uuid.replace(/-/g, '').slice(0, 8);
}

// Legacy 6-char hex shortId
function newLegacyId() {
  return randomBytes(3).toString('hex'); // 6 hex chars
}

function nowISO() {
  return new Date().toISOString();
}

function sanitizeCwd(cwd) {
  return cwd.replace(/[/\\:]/g, '-').replace(/^-+/, '') || 'root';
}

// ---------- sidecar helpers (Plan 0002 T3) ----------

function sidecarDir(shortId) {
  return join(HOME, 'jobs', shortId);
}

function writeSidecar(shortId, data) {
  const dir = sidecarDir(shortId);
  mkdirSync(dir, { recursive: true });
  writeFileSync(join(dir, 'state.json'), JSON.stringify(data, null, 2));
}

function appendTimeline(shortId, entry) {
  const dir = sidecarDir(shortId);
  mkdirSync(dir, { recursive: true });
  appendFileSync(join(dir, 'timeline.jsonl'), JSON.stringify(entry) + '\n');
}

function buildSidecarBase(config, shortId, sessionId, sessionName, cwd, prompt) {
  const sanitized = sanitizeCwd(cwd);
  return {
    template: 'bg',
    intent: prompt,
    name: sessionName,
    nameSource: 'user',
    sessionId,
    resumeSessionId: sessionId,
    daemonShort: shortId,
    cliVersion: config.version,
    cwd,
    backend: 'daemon',
    linkScanPath: join(HOME, 'projects', sanitized, `${sessionId}.jsonl`),
  };
}

function formatResponse(config, prompt) {
  return config.attachResponse.replace('${prompt}', prompt);
}

// ---------- review fixture helpers (Plan 0003 T9) ----------

/**
 * Load a review fixture file from fixtures/reviews/<name>.txt.
 * Returns the file contents as a string, or a fallback string on read error.
 *
 * @param {string} name - Fixture name without the .txt extension.
 * @returns {string}
 */
function loadReviewFixture(name) {
  const fixturePath = join(MOCK_DIR, 'fixtures', 'reviews', `${name}.txt`);
  try {
    return readFileSync(fixturePath, 'utf8');
  } catch {
    return `[mock] Could not load review fixture: ${name}`;
  }
}

/**
 * Detect whether a prompt is a same-session review prompt (attach path).
 * Matches on the stable substring unique to SAME_SESSION_REVIEW_PROMPT output.
 *
 * @param {string} prompt
 * @returns {boolean}
 */
function isReviewPromptAttach(prompt) {
  return prompt.includes('You are acting as an independent code reviewer');
}

/**
 * Detect whether a prompt is an adversarial review prompt (--bg path).
 * Matches on the data-delimiter line unique to ADVERSARIAL_REVIEW_PROMPT output.
 *
 * @param {string} prompt
 * @returns {boolean}
 */
function isReviewPromptBg(prompt) {
  return prompt.includes('--- BEGIN REVIEWED OUTPUT ---');
}

/**
 * Resolve the review fixture name for the attach path.
 * If config.reviewFixture is set, use it; otherwise default to "structured-review".
 *
 * @param {object} config
 * @returns {string}
 */
function resolveAttachReviewFixture(config) {
  if (config.reviewFixture != null) return config.reviewFixture;
  return 'structured-review';
}

/**
 * Resolve the review fixture name for the --bg path.
 * If config.reviewFixture is set, use it; otherwise default to "adversarial-review".
 *
 * @param {object} config
 * @returns {string}
 */
function resolveBgReviewFixture(config) {
  if (config.reviewFixture != null) return config.reviewFixture;
  return 'adversarial-review';
}

/**
 * Decide whether to use the review fixture for a given prompt.
 *
 * The review fixture path activates when EITHER:
 *   (a) config.reviewFixture is explicitly set (non-null) — always use fixture, OR
 *   (b) the prompt matches the review heuristic AND config.attachResponse is still
 *       the default (i.e. NOT explicitly overridden in the config file). When the
 *       caller has explicitly set attachResponse, that value takes precedence so
 *       existing tests that seed structured/malformed content via attachResponse
 *       continue to work without interference.
 *
 * @param {object} config
 * @param {boolean} isReviewPrompt
 * @returns {boolean}
 */
function shouldUseReviewFixture(config, isReviewPrompt) {
  if (config.reviewFixture != null) return true;
  // Only activate auto-detection when attachResponse is still the default value.
  return isReviewPrompt && config.attachResponse === DEFAULT_CONFIG.attachResponse;
}

function findSession(state, id) {
  return state.sessions.find((s) => s.shortId === id || s.sessionId === id);
}

// ---------- argument parsing ----------

// Flags on `claude --bg` that consume a value. Unknown flags are ignored (best effort).
const BG_VALUE_FLAGS = new Set([
  '--name',
  '--model',
  '--effort',
  '--permission-mode',
  '--add-dir',
  '--mcp-config',
  '--settings',
  '--fallback-model',
  '--agent',
]);

function parseBgArgs(args) {
  let name;
  const positional = [];
  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    if (BG_VALUE_FLAGS.has(a)) {
      const val = args[++i];
      if (a === '--name') name = val;
      // Other recognized value-flags are accepted and ignored by the mock.
    } else if (a.startsWith('--')) {
      // Unknown flag. If the next token doesn't start with `--`, consume it as a value.
      if (i + 1 < args.length && !args[i + 1].startsWith('--')) {
        i++;
      }
    } else {
      positional.push(a);
    }
  }
  return { name, prompt: positional.join(' ') };
}

// ---------- commands ----------

function cmdVersion(config) {
  process.stdout.write(`Claude Code ${config.version}\n`);
  return 0;
}

function cmdAuthStatus(config) {
  if (config.authStatus === 'authenticated') {
    process.stdout.write('Logged in\n');
    return 0;
  }
  process.stdout.write('Not logged in. Run `claude login`.\n');
  return 1;
}

function cmdDaemonStatus(config) {
  // In real mode (daemonAvailable: false), daemon subcommand does not exist
  if (!config.daemonAvailable) {
    process.stderr.write("claude: 'daemon' is not a known command\n");
    return 1;
  }
  if (config.daemonStatus === 'running') {
    process.stdout.write('Claude daemon: running\n');
    return 0;
  }
  process.stdout.write('Claude daemon: stopped\n');
  return 1;
}

function cmdBg(config, args) {
  if (config.bgFails) {
    process.stderr.write('Failed to start background session\n');
    return 1;
  }
  ensureHome();
  const { name, prompt } = parseBgArgs(args);
  const cwd = process.cwd();
  const startedAt = nowISO();

  let shortId, sessionId, sessionName;

  if (config.agentsJsonSchema === 'mock') {
    // Legacy mock mode: 6-hex shortId, session-<shortId> sessionId
    shortId = newLegacyId();
    sessionId = `session-${shortId}`;
    sessionName = name || `bg-${shortId}`;
  } else {
    // Real mode: UUID sessionId, 8-hex shortId derived from UUID
    sessionId = newUUID();
    shortId = deriveShortIdFromUUID(sessionId);
    sessionName = name || `bg-${shortId}`;
  }

  const projectDir = join(HOME, 'projects', sanitizeCwd(cwd));
  mkdirSync(projectDir, { recursive: true });
  const transcriptPath = join(projectDir, `${sessionId}.jsonl`);
  const logPath = join(HOME, 'logs', `${shortId}.log`);

  const transcriptLines = [
    JSON.stringify({
      type: 'meta',
      sessionId,
      startedAt,
      cwd,
      sessionName,
    }),
    JSON.stringify({
      type: 'message',
      role: 'user',
      content: prompt,
      at: startedAt,
    }),
    JSON.stringify({
      type: 'message',
      role: 'assistant',
      content: `[mock] Starting work on: ${prompt}`,
      at: startedAt,
    }),
  ];
  writeFileSync(transcriptPath, transcriptLines.join('\n') + '\n');
  appendFileSync(
    logPath,
    `[${startedAt}] Session ${shortId} started\n[${startedAt}] Prompt: ${prompt}\n`,
  );

  const state = loadState();
  state.sessions.push({
    shortId,
    sessionId,
    name: sessionName,
    cwd,
    pid: process.pid,
    status: 'working',
    startedAt,
    updatedAt: startedAt,
    transcriptPath,
    logPath,
    prompt,
  });
  saveState(state);

  // Plan 0002 T3: write sidecar files under <HOME>/jobs/<shortId>/
  const base = buildSidecarBase(config, shortId, sessionId, sessionName, cwd, prompt);
  if (!prompt) {
    // No-prompt invocation: idle session
    writeSidecar(shortId, {
      ...base,
      state: 'idle',
      tempo: 'idle',
      inFlight: { tasks: 0, queued: 0, kinds: [] },
    });
    appendTimeline(shortId, {
      at: startedAt,
      state: 'idle',
      detail: 'session created (idle, awaiting prompt)',
    });
  } else {
    // Prompt provided: working → done
    writeSidecar(shortId, {
      ...base,
      state: 'working',
      tempo: 'active',
      inFlight: { tasks: 1, queued: 0, kinds: [] },
    });
    appendTimeline(shortId, { at: startedAt, state: 'working', detail: 'starting turn' });

    // Plan 0003 T9: detect review prompts and return the appropriate fixture.
    let response;
    if (shouldUseReviewFixture(config, isReviewPromptBg(prompt))) {
      const fixtureName = resolveBgReviewFixture(config);
      response = loadReviewFixture(fixtureName);
    } else {
      response = formatResponse(config, prompt);
    }
    writeSidecar(shortId, {
      ...base,
      state: 'done',
      tempo: 'idle',
      inFlight: { tasks: 0, queued: 0, kinds: [] },
      output: { result: response },
    });
    appendTimeline(shortId, {
      at: startedAt,
      state: 'done',
      detail: 'turn complete',
      text: response,
    });
  }

  if (config.bgStdoutStyle === 'started-session') {
    // Legacy format
    if (!prompt) {
      process.stdout.write(`Started background session ${shortId} (idle)\n`);
    } else {
      process.stdout.write(`Started background session ${shortId}\n`);
    }
  } else {
    // Real 2.1.149 format
    if (!prompt) {
      process.stdout.write(
        `Starting background service…\nbackgrounded · ${shortId} (idle — send a prompt to start)\n  claude agents             list sessions\n  claude attach ${shortId}   open in this terminal\n  claude logs ${shortId}     show recent output\n`,
      );
    } else {
      process.stdout.write(
        `Starting background service…\nbackgrounded · ${shortId}\n  claude agents             list sessions\n  claude attach ${shortId}   open in this terminal\n  claude logs ${shortId}     show recent output\n`,
      );
    }
  }
  return 0;
}

function cmdAgentsJson(config) {
  if (config.agentsJsonFails) {
    process.stderr.write('agents error\n');
    return 1;
  }
  if (config.agentsJsonMalformed) {
    process.stdout.write('{not-json\n');
    return 0;
  }
  const state = loadState();

  let out;
  if (config.agentsJsonSchema === 'mock') {
    // Legacy mock schema: full fields including id, shortId, name, updatedAt, transcriptPath
    out = state.sessions.map((s) => ({
      id: s.shortId,
      shortId: s.shortId,
      sessionId: s.sessionId,
      name: s.name,
      cwd: s.cwd,
      pid: s.pid,
      status: s.status,
      startedAt: s.startedAt,
      updatedAt: s.updatedAt,
      transcriptPath: s.transcriptPath,
    }));
  } else {
    // Real 2.1.149 schema: pid, cwd, kind, startedAt (unix ms int), sessionId, status
    // No id, shortId, name, updatedAt, transcriptPath
    out = state.sessions.map((s) => ({
      pid: s.pid,
      cwd: s.cwd,
      kind: 'interactive',
      startedAt: new Date(s.startedAt).getTime(),
      sessionId: s.sessionId,
      status: s.status,
    }));
  }

  process.stdout.write(JSON.stringify(out, null, 2) + '\n');
  return 0;
}

function cmdLogs(config, args) {
  const id = args[0];
  if (id === '--help' || id === '-h') {
    process.stdout.write('usage: claude logs <id>\n');
    return 0;
  }
  if (!id) {
    process.stderr.write('usage: claude logs <id>\n');
    return 2;
  }
  if (config.logsFail) {
    process.stderr.write('logs unavailable\n');
    return 1;
  }
  const state = loadState();
  const session = findSession(state, id);
  if (!session) {
    process.stderr.write(`unknown session: ${id}\n`);
    return 1;
  }
  if (existsSync(session.logPath)) {
    process.stdout.write(readFileSync(session.logPath, 'utf8'));
  }
  return 0;
}

// Plan 0002 T3: full PTY-attach emulation for `claude attach <id>`.
function cmdAttach(config, args) {
  const sub = args[0];
  if (sub === '--help' || sub === '-h') {
    if (!config.attachHelpAvailable) {
      process.stderr.write("claude: 'attach' is not a known command\n");
      return 1;
    }
    process.stdout.write(
      'Usage: claude attach <id>\n\n  Open the background session in this terminal. Detach with Ctrl+Z; the session keeps running.\n',
    );
    return 0;
  }
  if (!sub) {
    process.stderr.write('usage: claude attach <id>\n');
    return 2;
  }

  const state = loadState();
  const session = findSession(state, sub);
  if (!session) {
    process.stderr.write(`unknown session: ${sub}; cannot attach\n`);
    return 1;
  }

  // Set raw mode on stdin if it is a TTY (i.e. under node-pty).
  if (process.stdin.isTTY) {
    process.stdin.setRawMode(true);
  }
  process.stdin.resume();

  let buf = '';
  let awaitingPermissionAnswer = false;
  let firstTurn = true;
  let pendingPrompt = '';

  function processSubmit(rawBuf) {
    const prompt = rawBuf;

    // Permission stall path: first turn, not yet waiting for answer
    if (config.permissionStall && firstTurn && !awaitingPermissionAnswer) {
      pendingPrompt = prompt;

      const now = nowISO();
      const base = buildSidecarBase(
        config,
        session.shortId,
        session.sessionId,
        session.name,
        session.cwd,
        pendingPrompt,
      );
      writeSidecar(session.shortId, {
        ...base,
        state: 'waiting',
        tempo: 'idle',
        inFlight: { tasks: 0, queued: 0, kinds: ['permission'] },
      });
      appendTimeline(session.shortId, {
        at: now,
        state: 'waiting',
        detail: 'agent requested permission',
      });

      process.stdout.write('Permission required. Type your answer and press Enter:\r\n');
      awaitingPermissionAnswer = true;
      return;
    }

    // Permission answer path: this submit IS the answer
    if (awaitingPermissionAnswer) {
      awaitingPermissionAnswer = false;
      // Fall through with the original prompt, not the permission answer
    } else {
      pendingPrompt = prompt;
    }

    // Process the turn
    const now = nowISO();
    const base = buildSidecarBase(
      config,
      session.shortId,
      session.sessionId,
      session.name,
      session.cwd,
      pendingPrompt,
    );

    writeSidecar(session.shortId, {
      ...base,
      state: 'working',
      tempo: 'active',
      inFlight: { tasks: 1, queued: 0, kinds: [] },
    });
    appendTimeline(session.shortId, { at: now, state: 'working', detail: 'starting turn' });

    // Plan 0003 T9: detect review prompts and return the appropriate fixture.
    let response;
    if (shouldUseReviewFixture(config, isReviewPromptAttach(pendingPrompt))) {
      const fixtureName = resolveAttachReviewFixture(config);
      response = loadReviewFixture(fixtureName);
    } else {
      response = formatResponse(config, pendingPrompt);
    }
    process.stdout.write(response + '\r\n');

    // Plan 0003 T12b: optional sidecar-summary override. When config has
    // `sidecarSummaryOnSubmit` set, that value is written to
    // sidecar.output.result instead of the full PTY `response`. This mimics
    // real Claude Code 2.1.150 behavior where the sidecar carries a short
    // summary while the full assistant message lands in the transcript.
    // When the override is in play we also append a `{type:'message',
    // role:'assistant',content:<response>}` line to the transcript so the
    // reconciler's transcript-events path can still recover the full text.
    const sidecarResultValue =
      typeof config.sidecarSummaryOnSubmit === 'string'
        ? config.sidecarSummaryOnSubmit
        : response;
    writeSidecar(session.shortId, {
      ...base,
      state: 'done',
      tempo: 'idle',
      inFlight: { tasks: 0, queued: 0, kinds: [] },
      output: { result: sidecarResultValue },
    });
    if (typeof config.sidecarSummaryOnSubmit === 'string' && session.transcriptPath) {
      try {
        // Ensure parent dir exists (synthetic-test setup may have written
        // session.transcriptPath into state.json without pre-creating the
        // projects/ subdir).
        mkdirSync(join(session.transcriptPath, '..'), { recursive: true });
        appendFileSync(
          session.transcriptPath,
          JSON.stringify({
            type: 'message',
            role: 'assistant',
            content: response,
            at: now,
          }) + '\n',
        );
      } catch {
        // best-effort; not a hard failure for the mock
      }
    }
    appendTimeline(session.shortId, {
      at: now,
      state: 'done',
      detail: 'turn complete',
      text: response,
    });

    firstTurn = false;
  }

  // Plan 0003 T12a: real Claude TUI input encoding for long prompts is
  // bracketed-paste-wrapped:  ESC[200~ <content> ESC[201~ CR. The driver
  // uses this wrap for ALL prompts now (short and long). Strip the markers
  // before processing so the mock continues to see the raw content.
  function stripBracketedPaste(s) {
    return s.replace(/\[200~/g, '').replace(/\[201~/g, '');
  }
  process.stdin.on('data', (chunk) => {
    for (let i = 0; i < chunk.length; i++) {
      const byte = typeof chunk[i] === 'number' ? chunk[i] : chunk.charCodeAt(i);
      if (byte === 0x1a) {
        // Ctrl+Z: detach immediately, no sidecar mutation
        process.exit(0);
      } else if (byte === 0x0d || byte === 0x0a) {
        // Enter (\r or \n): submit. Plan 0003 T12a: skip empty submits so
        // CRLF terminators (or stray LF after bracketed-paste close) don't
        // fire a second (empty) submit that clobbers the response. PTY
        // line discipline (icrnl) may convert CR to LF before this handler
        // sees it, so we cannot reliably detect "LF immediately after CR"
        // from raw bytes — the simpler rule "an empty submit is a no-op"
        // handles all cases (CRLF, CR, LF, LF+LF) without lookback.
        const cleaned = stripBracketedPaste(buf);
        buf = '';
        if (cleaned.length === 0) continue;
        processSubmit(cleaned);
      } else {
        buf += String.fromCharCode(byte);
      }
    }
  });

  // Keep process alive while reading stdin; stdin 'end' means EOF → exit cleanly
  process.stdin.on('end', () => {
    process.exit(0);
  });

  // Return -1 to signal the caller that the process should NOT call process.exit()
  // immediately; the event loop handles exit.
  return -1;
}

function cmdStop(config, args) {
  const id = args[0];
  if (!id) {
    process.stderr.write('usage: claude stop <id>\n');
    return 2;
  }
  const state = loadState();
  const session = findSession(state, id);
  if (!session) {
    process.stderr.write(`unknown session: ${id}\n`);
    return 1;
  }
  const now = nowISO();
  session.status = 'stopped';
  session.updatedAt = now;
  saveState(state);
  appendFileSync(session.logPath, `[${now}] Session ${session.shortId} stopped\n`);
  process.stdout.write(`Stopped session ${session.shortId}\n`);

  // Plan 0002 T3: update sidecar to reflect stopped state
  const base = buildSidecarBase(
    config,
    session.shortId,
    session.sessionId,
    session.name,
    session.cwd,
    session.prompt || '',
  );
  writeSidecar(session.shortId, {
    ...base,
    state: 'stopped',
    tempo: 'idle',
    inFlight: { tasks: 0, queued: 0, kinds: [] },
  });
  appendTimeline(session.shortId, { at: now, state: 'stopped', detail: 'session stopped' });

  return 0;
}

// ---------- dispatch ----------

function maybeSleep(config) {
  // Test hook: simulate a slow command to exercise the doctor's timeout path.
  if (typeof config.sleepMs === 'number' && config.sleepMs > 0) {
    Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, config.sleepMs);
  }
}

function main() {
  const argv = process.argv.slice(2);
  const config = loadConfig();
  maybeSleep(config);

  if (argv[0] === '--version') return process.exit(cmdVersion(config));
  if (argv[0] === '--help' || argv[0] === '-h') {
    if (config.helpListsBg) {
      process.stdout.write(
        'mock-claude: --version | auth status | daemon status | --bg <prompt> | agents --json | logs <id> | stop <id>\n',
      );
    } else {
      process.stdout.write(
        'mock-claude: --version | auth status | agents --json | logs <id> | stop <id>\n',
      );
    }
    return process.exit(0);
  }
  if (argv[0] === 'auth' && argv[1] === 'status') return process.exit(cmdAuthStatus(config));
  if (argv[0] === 'daemon' && argv[1] === 'status') return process.exit(cmdDaemonStatus(config));
  // Plan 0002 probe target: `claude --bg --help` must be recognized as a help request,
  // not as an attempt to start a session with a "--help" prompt. Configurable via
  // bgNoPromptAvailable so tests can exercise the doctor's failure path.
  if (argv[0] === '--bg' && (argv[1] === '--help' || argv[1] === '-h')) {
    if (!config.bgNoPromptAvailable) {
      process.stderr.write(
        "claude: '--bg' does not accept '--help' (no-prompt invocation rejected by this binary)\n",
      );
      return process.exit(1);
    }
    process.stdout.write(
      'Usage: claude --bg [options] [prompt]\n\n  Start a Claude background session. Pass a prompt to begin immediately; omit it to start in idle and send a prompt via `claude attach <id>`.\n',
    );
    return process.exit(0);
  }
  if (argv[0] === '--bg') return process.exit(cmdBg(config, argv.slice(1)));
  if (argv[0] === 'agents' && argv[1] === '--json') return process.exit(cmdAgentsJson(config));
  if (argv[0] === 'attach') {
    const rc = cmdAttach(config, argv.slice(1));
    // rc === -1 means cmdAttach set up an event-loop listener; do not call exit() now.
    if (rc !== -1) return process.exit(rc);
    return;
  }
  if (argv[0] === 'logs') return process.exit(cmdLogs(config, argv.slice(1)));
  if (argv[0] === 'stop') return process.exit(cmdStop(config, argv.slice(1)));

  process.stderr.write(`mock-claude: unknown command: ${argv.join(' ') || '(none)'}\n`);
  process.stderr.write(
    'Supported: --version, auth status, daemon status, --bg <prompt>, agents --json, logs <id>, stop <id>\n',
  );
  process.exit(2);
}

main();

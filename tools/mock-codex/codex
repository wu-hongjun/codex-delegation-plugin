#!/usr/bin/env node
// Mock `codex` binary used by codex-delegation-plugin tests. Only implements `codex --version`
// today — enough to satisfy the `codex-version` doctor probe without depending on a
// real Codex install. Extend the surface only as future probes/skills need it.

import { appendFileSync, existsSync, mkdirSync, readFileSync } from 'node:fs';
import { dirname } from 'node:path';

const CONFIG_PATH = process.env.CODEX_DELEGATION_MOCK_CODEX_CONFIG;

const DEFAULT_CONFIG = Object.freeze({
  version: 'codex-cli 0.0.0-mock',
  versionFails: false,
  pluginListVersion: '0.0.0-mock',
  pluginInstalledPath: '',
  pluginFailures: {},
  commandLogPath: '',
  sleepMs: 0,
});

function loadConfig() {
  if (!CONFIG_PATH || !existsSync(CONFIG_PATH)) return { ...DEFAULT_CONFIG };
  try {
    return { ...DEFAULT_CONFIG, ...JSON.parse(readFileSync(CONFIG_PATH, 'utf8')) };
  } catch {
    return { ...DEFAULT_CONFIG };
  }
}

function maybeSleep(config) {
  if (typeof config.sleepMs === 'number' && config.sleepMs > 0) {
    Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, config.sleepMs);
  }
}

function logCommand(config, argv) {
  if (!config.commandLogPath) return;
  mkdirSync(dirname(config.commandLogPath), { recursive: true });
  appendFileSync(config.commandLogPath, JSON.stringify({ argv }) + '\n');
}

function maybeFailPluginCommand(config, commandKey) {
  const failure = config.pluginFailures?.[commandKey];
  if (!failure) return false;
  const message = typeof failure === 'string' ? failure : `mock failure for ${commandKey}`;
  process.stderr.write(`${message}\n`);
  process.exit(1);
}

function main() {
  const argv = process.argv.slice(2);
  const config = loadConfig();
  maybeSleep(config);

  if (argv[0] === '--version') {
    if (config.versionFails) {
      process.stderr.write('codex error\n');
      process.exit(1);
    }
    process.stdout.write(`${config.version}\n`);
    process.exit(0);
  }

  if (argv[0] === 'plugin') {
    const commandKey = argv.join(' ');
    logCommand(config, argv);
    maybeFailPluginCommand(config, commandKey);

    if (argv[1] === 'marketplace' && argv[2] === 'upgrade' && argv[3]) {
      process.stdout.write(`Upgraded marketplace ${argv[3]}\n`);
      process.exit(0);
    }

    if (argv[1] === 'marketplace' && argv[2] === 'add' && argv[3]) {
      process.stdout.write(`Added marketplace ${argv[3]}\n`);
      process.exit(0);
    }

    if (argv[1] === 'remove' && argv[2]) {
      process.stdout.write(`Removed plugin ${argv[2]}\n`);
      process.exit(0);
    }

    if (argv[1] === 'add' && argv[2]) {
      if (argv.includes('--json')) {
        const selector = argv[2];
        const [name, marketplaceName = 'mock-marketplace'] = selector.split('@');
        process.stdout.write(
          JSON.stringify(
            {
              pluginId: selector,
              name,
              marketplaceName,
              version: config.pluginListVersion,
              installedPath:
                config.pluginInstalledPath ||
                `/tmp/mock-codex-cache/${marketplaceName}/${name}/${config.pluginListVersion}`,
            },
            null,
            2,
          ) + '\n',
        );
        process.exit(0);
      }
      process.stdout.write(`Added plugin ${argv[2]}\n`);
      process.exit(0);
    }

    if (argv[1] === 'list') {
      process.stdout.write(
        `delegate@codex-delegation-plugin  enabled  ${config.pluginListVersion}\n`,
      );
      process.exit(0);
    }
  }

  process.stderr.write(`mock-codex: unsupported command: ${argv.join(' ') || '(none)'}\n`);
  process.exit(2);
}

main();
